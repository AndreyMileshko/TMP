<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tmp.ui.shell.screen.audit.SecurityAuditController"
      spacing="12">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>
    <Label text="Журнал аудита безопасности" styleClass="audit-title"/>
    <HBox spacing="8">
        <TextField fx:id="operationFilterField" promptText="Операция" prefWidth="200"/>
        <Button fx:id="applyFilterButton" text="Применить фильтр"/>
    </HBox>
    <TableView fx:id="auditTable" prefHeight="320">
        <columns>
            <TableColumn fx:id="occurredAtColumn" text="Время" prefWidth="160"/>
            <TableColumn fx:id="actorColumn" text="Актор" prefWidth="120"/>
            <TableColumn fx:id="operationColumn" text="Операция" prefWidth="140"/>
            <TableColumn fx:id="targetColumn" text="Цель" prefWidth="160"/>
            <TableColumn fx:id="descriptionColumn" text="Описание" prefWidth="220"/>
            <TableColumn fx:id="resultColumn" text="Результат" prefWidth="90"/>
        </columns>
    </TableView>
    <HBox spacing="8" alignment="CENTER_LEFT">
        <Button fx:id="previousPageButton" text="Назад"/>
        <Label fx:id="pageLabel"/>
        <Button fx:id="nextPageButton" text="Вперёд"/>
    </HBox>
    <Label fx:id="errorLabel" styleClass="audit-error" visible="false" managed="false" wrapText="true"/>
</VBox>
